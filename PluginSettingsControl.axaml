<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:views="clr-namespace:ConvenientText.Views"
             xmlns:conv="clr-namespace:ConvenientText.Converters"
             x:Class="ConvenientText.PluginSettingsControl"
             HorizontalAlignment="Stretch"
             VerticalAlignment="Stretch">
	<UserControl.Resources>
		<ResourceDictionary>
			<ResourceDictionary.ThemeDictionaries>
				<!-- 深色模式：半透明白色卡片 -->
				<ResourceDictionary x:Key="Dark">
					<SolidColorBrush x:Key="CardBackgroundBrush" Color="#14FFFFFF" />
					<SolidColorBrush x:Key="CardBorderBrush" Color="#26FFFFFF" />
				</ResourceDictionary>
				<!-- 浅色模式：纯白卡片 + 浅灰描边 -->
				<ResourceDictionary x:Key="Light">
					<SolidColorBrush x:Key="CardBackgroundBrush" Color="White" />
					<SolidColorBrush x:Key="CardBorderBrush" Color="#1F000000" />
				</ResourceDictionary>
			</ResourceDictionary.ThemeDictionaries>
		</ResourceDictionary>
	</UserControl.Resources>
	<ScrollViewer HorizontalScrollBarVisibility="Disabled"
                  VerticalScrollBarVisibility="Auto">
		<!-- 居中限宽栏：左缘与 ClassIsland 页面标题对齐 -->
		<StackPanel HorizontalAlignment="Stretch"
                    MaxWidth="960"
                    Spacing="14"
                    Margin="16,12,16,20">
			
			<!-- ===== 页头 ===== -->
			<StackPanel Orientation="Horizontal" Spacing="12" Margin="4,4,4,0">
				<TextBlock Text="✎"
                           FontSize="26"
                           VerticalAlignment="Center" />
				<StackPanel VerticalAlignment="Center">
					<TextBlock Text="便捷文本 · 设置 TEST"
                               FontWeight="Bold"
                               FontSize="20" />
					<TextBlock Text="悬浮按钮快速改字 · 时间段控制 · U盘防断头提醒"
                               FontSize="12"
                               Foreground="{DynamicResource SystemControlDisabledChromeDisabledBrush}" />
				</StackPanel>
			</StackPanel>

			<!-- ===== 卡片：预设管理 ===== -->
			<Border CornerRadius="8"
					Background="{DynamicResource CardBackgroundBrush}"
					BorderBrush="{DynamicResource CardBorderBrush}"
                    BorderThickness="1"
                    Padding="16">
				<StackPanel Spacing="10">
					<StackPanel Orientation="Horizontal" Spacing="10">
						<TextBlock Text="📋" FontSize="18" VerticalAlignment="Center" />
						<StackPanel VerticalAlignment="Center">
							<TextBlock Text="预设管理" FontWeight="SemiBold" FontSize="15" />
							<TextBlock Text="全局预设库，编辑文本时可以一键加载"
                                       FontSize="12"
                                       Foreground="{DynamicResource SystemControlDisabledChromeDisabledBrush}" />
						</StackPanel>
					</StackPanel>

					<ListBox x:Name="PresetListBox"
                             MaxHeight="160"
                             Background="Transparent"
                             BorderThickness="0">
						<ListBox.ItemTemplate>
							<DataTemplate>
								<Border CornerRadius="6"
                                        Padding="10,6"
                                        Margin="0,2">
									<Border.Styles>
										<Style Selector="Border:pointerover">
											<Setter Property="Background" Value="{DynamicResource SystemControlBackgroundChromeHighBrush}" />
										</Style>
									</Border.Styles>
									<Grid>
										<Grid.ColumnDefinitions>
											<ColumnDefinition Width="*" />
											<ColumnDefinition Width="Auto" />
										</Grid.ColumnDefinitions>
										<TextBlock Grid.Column="0"
                                                   Text="{Binding}"
                                                   VerticalAlignment="Center"
                                                   TextTrimming="CharacterEllipsis" />
										<Button Grid.Column="1"
                                                Content="✕"
                                                FontSize="13"
                                                Width="26"
                                                Height="26"
                                                Padding="0"
                                                CornerRadius="4"
                                                Background="Transparent"
                                                BorderThickness="0"
                                                Foreground="{DynamicResource SystemControlBaseHighBrush}"
                                                VerticalAlignment="Center"
                                                Click="OnDeletePresetClick"
                                                Tag="{Binding}">
											<Button.Styles>
												<Style Selector="Button:pointerover">
													<Setter Property="Background" Value="#E81123" />
													<Setter Property="Foreground" Value="White" />
												</Style>
											</Button.Styles>
										</Button>
									</Grid>
								</Border>
							</DataTemplate>
						</ListBox.ItemTemplate>
					</ListBox>

					<Grid>
						<Grid.ColumnDefinitions>
							<ColumnDefinition Width="*" />
							<ColumnDefinition Width="Auto" />
						</Grid.ColumnDefinitions>
						<TextBox x:Name="NewPresetInput"
                                 Watermark="输入新的预设文本..." />
						<Button Grid.Column="1"
                                Content="添加预设"
                                Classes="Accent"
                                Margin="8,0,0,0"
                                Click="OnAddPresetClick" />
					</Grid>
				</StackPanel>
			</Border>

			<!-- ===== 卡片：已添加的组件 ===== -->
			<Border CornerRadius="8"
                    Background="{DynamicResource CardBackgroundBrush}"
					BorderBrush="{DynamicResource CardBorderBrush}"
                    BorderThickness="1"
                    Padding="16">
				<StackPanel Spacing="10">
					<StackPanel Orientation="Horizontal" Spacing="10">
						<TextBlock Text="🧩" FontSize="18" VerticalAlignment="Center" />
						<StackPanel VerticalAlignment="Center">
							<TextBlock Text="已添加的组件" FontWeight="SemiBold" FontSize="15" />
							<TextBlock Text="点击组件进入详细设置；未加载的残留组件可点 ✕ 删除"
                                       FontSize="12"
                                       Foreground="{DynamicResource SystemControlDisabledChromeDisabledBrush}" />
						</StackPanel>
					</StackPanel>

					<ListBox x:Name="ComponentListBox"
                             MaxHeight="240"
                             Background="Transparent"
                             BorderThickness="0">
						<ListBox.ItemTemplate>
							<DataTemplate>
								<Border CornerRadius="6"
                                        Padding="10,8"
                                        Margin="0,2">
									<Border.Styles>
										<Style Selector="Border:pointerover">
											<Setter Property="Background" Value="{DynamicResource SystemControlBackgroundChromeHighBrush}" />
										</Style>
									</Border.Styles>
									<Grid>
										<Grid.ColumnDefinitions>
											<ColumnDefinition Width="Auto" />
											<ColumnDefinition Width="*" />
											<ColumnDefinition Width="Auto" />
											<ColumnDefinition Width="Auto" />
										</Grid.ColumnDefinitions>

										<TextBlock Grid.Column="0"
                                                   Text="●"
                                                   FontSize="18"
                                                   Foreground="{Binding Model.DotColor, Converter={x:Static conv:ColorToBrushConverter.Instance}}"
                                                   VerticalAlignment="Center"
                                                   Margin="0,0,10,0" />

										<StackPanel Grid.Column="1" VerticalAlignment="Center">
											<TextBlock FontWeight="SemiBold" FontSize="14">
												<TextBlock.Text>
													<MultiBinding StringFormat="组件 #{0}">
														<Binding Path="RowNumber" />
													</MultiBinding>
												</TextBlock.Text>
											</TextBlock>
											<TextBlock Text="{Binding Model.DisplayText}"
                                                       FontSize="13"
                                                       Opacity="0.7"
                                                       TextTrimming="CharacterEllipsis" />
										</StackPanel>

										<Button Grid.Column="2"
                                                Content="✕"
                                                FontSize="13"
                                                Width="26"
                                                Height="26"
                                                Padding="0"
                                                CornerRadius="4"
                                                Background="Transparent"
                                                BorderThickness="0"
                                                Foreground="{DynamicResource SystemControlBaseHighBrush}"
                                                VerticalAlignment="Center"
                                                Click="OnDeleteComponentClick"
                                                Tag="{Binding Model.ComponentId}">
											<Button.Styles>
												<Style Selector="Button:pointerover">
													<Setter Property="Background" Value="#E81123" />
													<Setter Property="Foreground" Value="White" />
												</Style>
											</Button.Styles>
										</Button>

										<TextBlock Grid.Column="3"
                                                   Text="▶"
                                                   FontSize="14"
                                                   Opacity="0.3"
                                                   Margin="8,0,0,0"
                                                   VerticalAlignment="Center" />
									</Grid>
								</Border>
							</DataTemplate>
						</ListBox.ItemTemplate>
					</ListBox>

					<TextBlock x:Name="EmptyComponentHint"
                               Text="暂无有效组件，请在主界面添加"
                               FontSize="13"
                               Foreground="{DynamicResource SystemControlDisabledChromeDisabledBrush}"
                               HorizontalAlignment="Center"
                               IsVisible="False" />
				</StackPanel>
			</Border>

			<!-- ===== 卡片：组件详细设置 ===== -->
			<Border x:Name="DetailPanel"
                    CornerRadius="8"
                    Background="{DynamicResource CardBackgroundBrush}"
					BorderBrush="{DynamicResource CardBorderBrush}"
                    BorderThickness="1"
                    Padding="16"
                    IsVisible="False">
				<views:ComponentSettingsPanel x:Name="SettingsPanel" />
			</Border>

			<!-- ===== 卡片：U盘提醒 ===== -->
			<Border CornerRadius="8"
					Background="{DynamicResource CardBackgroundBrush}"
					BorderBrush="{DynamicResource CardBorderBrush}"
                    BorderThickness="1"
                    Padding="16">
				<Grid>
					<Grid.ColumnDefinitions>
						<ColumnDefinition Width="Auto" />
						<ColumnDefinition Width="*" />
						<ColumnDefinition Width="Auto" />
					</Grid.ColumnDefinitions>
					<TextBlock Text="🔌"
                               FontSize="18"
                               VerticalAlignment="Center"
                               Margin="0,0,10,0" />
					<StackPanel Grid.Column="1" VerticalAlignment="Center">
						<TextBlock Text="U盘插入提醒"
                                   FontWeight="SemiBold"
                                   FontSize="15" />
						<TextBlock Text="检测到U盘插入时，弹出「防断头」温馨提示"
                                   FontSize="12"
                                   Foreground="{DynamicResource SystemControlDisabledChromeDisabledBrush}" />
					</StackPanel>
					<ToggleSwitch x:Name="UsbNotificationToggle"
                                  Grid.Column="2"
                                  VerticalAlignment="Center"
                                  OnContent="开"
                                  OffContent="关" />
				</Grid>
			</Border>

			<TextBlock Text="所有修改都会自动保存"
                       FontSize="12"
                       Foreground="{DynamicResource SystemControlDisabledChromeDisabledBrush}"
                       HorizontalAlignment="Center" />
		</StackPanel>
	</ScrollViewer>
</UserControl>
